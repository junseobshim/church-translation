# Soniox API key for real-time speech-to-text
SONIOX_API_KEY=your-soniox-api-key-here

# Anthropic API key for Claude translation
ANTHROPIC_API_KEY=sk-ant-...

# Claude model for translation (optional — defaults to claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# ElevenLabs API key for Scribe v2 real-time transcription
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Google Cloud / Vertex AI (for Gemini translation)
# Path to service account JSON file (project ID is read from it automatically)
GCP_SERVICE_ACCOUNT_KEY=./path-to-service-account.json
# GCP_REGION=us-east4
